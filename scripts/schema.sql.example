-- ============================================
-- Comments
-- ============================================

COMMENT ON SCHEMA app IS 'Main application schema';
COMMENT ON SCHEMA audit IS 'Audit and logging schema';
COMMENT ON SCHEMA config IS 'Configuration and static data schema';

COMMENT ON TABLE app.users IS 'Application users';
COMMENT ON TABLE app.organizations IS 'Organizations/tenants';
COMMENT ON TABLE app.documents IS 'Main documents table';
COMMENT ON TABLE audit.audit_log IS 'Audit trail for all changes';

-- Schema creation completed
SELECT 'Schema created successfully!' AS status;